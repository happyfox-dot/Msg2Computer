{
  "name": "code-sync-desktop",
  "version": "1.0.24",
  "description": "跨设备验证码同步工具 - 桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.codesync.desktop",
    "productName": "验证码同步",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.3",
    "qrcode-decoder": "^0.3.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
