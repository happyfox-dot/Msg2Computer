<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_row"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_marginBottom="6dp">

    <FrameLayout
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="10dp">

        <ProgressBar
            android:id="@+id/totpProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:indeterminate="false"
            android:max="30"
            android:progress="30"
            android:progressDrawable="@drawable/ring_totp_progress" />

        <TextView
            android:id="@+id/totpRemaining"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:text="30" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/totpLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOTP"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/totpCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="000000"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <TextView
        android:id="@+id/totpPin"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="6dp"
        android:gravity="center"
        android:text="☆"
        android:textColor="@color/warning"
        android:textSize="18sp"
        android:contentDescription="@string/totp_pin" />

    <ImageView
        android:id="@+id/totpCopy"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_copy"
        android:contentDescription="@string/copy"
        app:tint="@color/text_secondary" />

</LinearLayout>
